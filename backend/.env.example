# Required — shared secret between the Gmail Add-on and backend for HMAC request signing.
# Must match the HMAC_SECRET script property in the Apps Script project.
# Generate a strong value with: python -c "import secrets; print(secrets.token_hex(32))"
HMAC_SECRET=change-me-to-a-random-secret

# Optional — controls structlog output level (DEBUG, INFO, WARNING, ERROR). Default: INFO.
LOG_LEVEL=INFO

# Optional — hard ceiling on the raw request body in bytes. Requests above
# this limit are rejected with 413 before HMAC verification reads the body.
# Default: 1048576 (1 MiB). Per-field Pydantic limits still apply on top.
MAX_REQUEST_BYTES=1048576

# Optional — per-IP fixed-window rate limit on /analyze. In-process and
# per-worker; for multi-worker or multi-host deployments, front the API
# with an upstream rate limiter (nginx, WAF) instead. Defaults: 60/60s.
RATE_LIMIT_PER_WINDOW=60
RATE_LIMIT_WINDOW_SECONDS=60

# Optional — backend that powers the LanguageAssessmentAnalyzer.
#   "local"  (default) — Ollama at LLM_HOST. Offline; email content never
#                        leaves the host.
#   "openai"           — OpenAI Chat Completions API. SECURITY TRADEOFF:
#                        sends email subjects and bodies to a third party.
LANGUAGE_PROVIDER=local

# Local provider (Ollama-compatible).
LLM_HOST=http://localhost:11434
LLM_MODEL=gemma:2b
# Request timeout in seconds. Default: 8 — short enough that a stalled
# Ollama falls back to a blind spot quickly instead of blocking the user.
LLM_TIMEOUT=8

# OpenAI provider — used only when LANGUAGE_PROVIDER=openai.
# Required when selected; the analyzer is silently disabled if missing.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=8

# Optional — wires the LanguageAssessmentAnalyzer (SLM-based classifier
# of social-engineering language) into the engine. Off by default so
# deployments without a reachable provider don't emit a
# LANGUAGE_ASSESSMENT blind spot on every email. Set to "true" once the
# selected LANGUAGE_PROVIDER is reachable.
LANGUAGE_ANALYZER_ENABLED=false
