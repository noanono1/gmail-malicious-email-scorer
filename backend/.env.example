# Required — shared secret between the Gmail Add-on and backend for HMAC request signing.
# Must match the HMAC_SECRET script property in the Apps Script project.
# Generate a strong value with: python -c "import secrets; print(secrets.token_hex(32))"
HMAC_SECRET=change-me-to-a-random-secret

# Optional — controls structlog output level (DEBUG, INFO, WARNING, ERROR). Default: INFO.
LOG_LEVEL=INFO

# Optional — hard ceiling on the raw request body in bytes. Requests above
# this limit are rejected with 413 before HMAC verification reads the body.
# Default: 1048576 (1 MiB). Per-field Pydantic limits still apply on top.
MAX_REQUEST_BYTES=1048576
